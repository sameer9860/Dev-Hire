# ─── Local development ────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DB_NAME=devhire
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Railway production (set these in Railway dashboard, not here) ─────────────
# Root Directory in Railway must be: backend
# Link Postgres → backend service so DATABASE_URL is injected automatically
# DJANGO_SECRET_KEY=your-strong-production-secret
# DEBUG=False
# ALLOWED_HOSTS=your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app